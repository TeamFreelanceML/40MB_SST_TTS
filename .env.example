# =============================================================================
# ReadAloud STT-TTS Production Environment Variables
# =============================================================================
# Copy this file to .env and change values for production deployment.
# =============================================================================

# --- REDIS SECURITY ---
# Change this to a long random string for production.
REDIS_PASSWORD=readaloud_secure_pass

# --- MODEL CONFIGURATION ---
# Choices: tiny, base, small, medium (base is recommended for low-latency)
STT_MODEL_NAME=base

# --- FRONTEND CONFIGURATION ---
# Set these to your production domain URLs
NEXT_PUBLIC_EVALUATION_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_TTS_WORD_API_URL=http://localhost:8001/narrate/word
